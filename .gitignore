# ==========================================================================
# FLTest .gitignore — conservative: track source only; ignore everything that
# is generated, downloaded, environment-, tool-, or machine-specific.
# ==========================================================================

# ---- Python bytecode / build artifacts ----
__pycache__/
*.py[cod]
*$py.class
*.so
build/
dist/
sdist/
wheels/
*.egg
*.egg-info/
.eggs/
.installed.cfg
MANIFEST

# ---- Virtual environments / interpreters ----
.venv/
venv/
env/
ENV/
env.bak/
venv.bak/
.python-version
.conda/
conda-meta/

# ---- Dependency lock/managers we don't track ----
poetry.lock
Pipfile.lock
pdm.lock
.pdm.toml
.pdm-python

# ---- Test / type / coverage caches ----
.pytest_cache/
.cache/
.coverage
.coverage.*
coverage.xml
htmlcov/
.tox/
.nox/
.mypy_cache/
.dmypy.json
.pyre/
.pytype/
.hypothesis/

# ---- FLTest runtime output (regenerated; can be large) ----
# data/ holds dataset + model + framework caches; reports/ holds JSON run/test reports.
data/
reports/
tmp/
validation_results/
nvflare_workspace/
*.simulate_job/

# ---- Docs build ----
site/
docs/_build/

# ---- Secrets / local config ----
.env
.env.*
*.local
local_settings.py

# ---- Editor / IDE ----
.idea/
.vscode/
*.swp
*.swo
*~
.spyderproject
.spyproject
.ropeproject

# ---- OS junk ----
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
Thumbs.db
ehthumbs.db
desktop.ini

# ---- Notebooks ----
.ipynb_checkpoints/

# ---- Logs / scratch ----
*.log

# ---- Claude Code / assistant tooling (never commit) ----
.claude/
CLAUDE.md
.aider*
